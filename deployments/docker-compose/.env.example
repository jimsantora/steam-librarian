# Steam Librarian Docker Compose Environment Variables
# Copy this file to .env and fill in your values

# Steam API Key (REQUIRED)
# Get your Steam API key from: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# Database Configuration (for production docker-compose)
DATABASE_PASSWORD=steam_password
POSTGRES_PASSWORD=steam_password

# Application Environment
SERVER_ENVIRONMENT=development
LOGGING_LEVEL=debug

# Optional: Override default ports
WEB_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Optional: Database connection settings
DATABASE_USERNAME=steam_librarian
DATABASE_DATABASE=steam_librarian

# Development vs Production profiles
# Uncomment one of these to use specific compose files:
# COMPOSE_FILE=docker-compose.dev.yml
# COMPOSE_FILE=docker-compose.yml