# Steam Librarian Environment Variables
# Copy this file to .env and fill in your values

# REQUIRED: Steam API Key
# Get your Steam API key from: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# Server Configuration
SERVER_ADDRESS=localhost:8080
SERVER_PORT=8080
SERVER_ENVIRONMENT=development

# Database Configuration
DATABASE_TYPE=sqlite
DATABASE_FILE_PATH=steam_librarian.db

# For PostgreSQL (uncomment and configure if using postgres)
# DATABASE_TYPE=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USERNAME=steam_librarian
# DATABASE_PASSWORD=your_password
# DATABASE_DATABASE=steam_librarian
# DATABASE_SSL_MODE=disable

# For MySQL (uncomment and configure if using mysql)
# DATABASE_TYPE=mysql
# DATABASE_HOST=localhost
# DATABASE_PORT=3306
# DATABASE_USERNAME=steam_librarian
# DATABASE_PASSWORD=your_password
# DATABASE_DATABASE=steam_librarian
# DATABASE_TIMEZONE=UTC

# Logging Configuration
LOGGING_LEVEL=debug
LOGGING_FORMAT=text

# Steam API Configuration
STEAM_RATE_LIMIT=200
STEAM_REQUEST_TIMEOUT=30s
STEAM_MAX_RETRIES=3
STEAM_SYNC_INTERVAL=24h
STEAM_BATCH_SIZE=10
STEAM_ENABLE_CACHING=true
STEAM_CACHE_EXPIRATION=6h

# MCP Server Configuration
MCP_ENABLED=true
MCP_SERVER_NAME=steam-librarian
MCP_PROTOCOL_VERSION=2024-11-05
MCP_TIMEOUT=30s